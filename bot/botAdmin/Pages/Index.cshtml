@page
@using botAdmin
@using System.IO
@{
    // ===== ОТЛАДКА: проверяем файл =====
    string dbPath = @"C:\Users\Professionals\Desktop\Практика\bot\botAdmin\teabot.db";
    bool fileExists = System.IO.File.Exists(dbPath);
    long fileSize = fileExists ? new System.IO.FileInfo(dbPath).Length : 0;

    var users = new List<User>();
    string errorMessage = "";

    try
    {
        users = Database.GetUsers();
    }
    catch (Exception ex)
    {
        errorMessage = ex.Message;
    }
}

<h1>🍵 Пользователи TEA</h1>

@if (!fileExists)
{
    <div style="color:red; padding:20px; background:#ffeeee; border:2px solid red; border-radius:8px;">
        <h3>❌ Файл teabot.db НЕ НАЙДЕН!</h3>
        <p>Искали по пути: <b>@dbPath</b></p>
        <p><b>Решение:</b> Скопируйте файл teabot.db из папки бота в папку botAdmin</p>
    </div>
}
else
{
    <div style="color:green; padding:10px; background:#eeffee; border:2px solid green; border-radius:8px;">
        ✅ Файл teabot.db найден! (размер: @fileSize байт)
    </div>
}

@if (!string.IsNullOrEmpty(errorMessage))
{
    <div style="color:red; padding:10px; background:#ffeeee; border:1px solid red; border-radius:8px;">
        <b>Ошибка базы данных:</b> @errorMessage
    </div>
}

@if (users.Count == 0)
{
    <p>⚠️ Пользователей пока нет. Напишите боту в ВК, чтобы появились данные.</p>
}
else
{
    <table border="1" style="border-collapse:collapse; width:100%;">
        <tr style="background:#B1B6B2; color:white;">
            <th style="padding:8px;">VK ID</th>
            <th style="padding:8px;">Язык</th>
            <th style="padding:8px;">Уровень</th>
            <th style="padding:8px;">Заявка</th>
        </tr>
        @foreach (var u in users)
        {
            <tr style="border-bottom:1px solid #B1B6B2;">
                <td style="padding:8px;">@u.VkUserId</td>
                <td style="padding:8px;">@u.Language</td>
                <td style="padding:8px;">@u.Level</td>
                <td style="padding:8px;">@u.Request</td>
            </tr>
        }
    </table>
}

<p><b>Всего пользователей:</b> @users.Count</p>

<p style="margin-top:20px;">
    <a href="/Requests">📋 Заявки менеджеру</a> |
    <a href="/Broadcast">📢 Рассылка</a>
</p>