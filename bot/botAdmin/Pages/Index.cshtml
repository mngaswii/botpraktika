@page
@using TeaBotSimple
@{
    // Получаем выбранную платформу из URL
    string platform = Request.Query["platform"].ToString();
    if (string.IsNullOrEmpty(platform)) platform = "all";

    var allUsers = Database.GetUsers();
    var vkUsers = allUsers.Where(u => u.Platform == "VK" || string.IsNullOrEmpty(u.Platform)).ToList();
    var maxUsers = allUsers.Where(u => u.Platform == "MAX").ToList();

    var displayUsers = platform == "all" ? allUsers :
                       platform == "VK" ? vkUsers : maxUsers;
}

<style>
    body {
        background-color: #F2DDCC;
        font-family: 'Segoe UI', sans-serif;
        margin: 0;
        padding: 20px;
    }

    h1 {
        color: #85544D;
    }

    .card {
        background-color: #F1C7A7;
        border-radius: 12px;
        padding: 20px;
        border: 1px solid #B1B6B2;
        margin-bottom: 20px;
    }

    table {
        width: 100%;
        border-collapse: collapse;
        background-color: #F2DDCC;
    }

    th {
        background-color: #B1B6B2;
        color: white;
        padding: 12px;
        text-align: left;
    }

    td {
        padding: 10px;
        border-bottom: 1px solid #B1B6B2;
    }

    .btn {
        background-color: #85544D;
        color: white;
        padding: 10px 20px;
        border: none;
        border-radius: 25px;
        cursor: pointer;
        text-decoration: none;
        display: inline-block;
        margin-right: 10px;
    }

        .btn:hover {
            background-color: #6B3E38;
        }

    .btn-active {
        background-color: #6B3E38;
    }

    .stats {
        display: flex;
        gap: 20px;
        margin-bottom: 20px;
        flex-wrap: wrap;
    }

    .stat-card {
        background-color: #F1C7A7;
        padding: 15px 25px;
        border-radius: 12px;
        text-align: center;
        border: 1px solid #B1B6B2;
    }

    .stat-number {
        font-size: 28px;
        font-weight: bold;
        color: #85544D;
    }

    .tabs {
        display: flex;
        gap: 10px;
        margin-bottom: 20px;
        flex-wrap: wrap;
    }

    .tab {
        padding: 10px 25px;
        border-radius: 25px;
        background-color: #F1C7A7;
        color: #85544D;
        text-decoration: none;
        border: 1px solid #B1B6B2;
    }

    .tab-active {
        background-color: #85544D;
        color: white;
    }

    .badge-vk {
        background-color: #4A76A8;
        color: white;
        padding: 3px 10px;
        border-radius: 15px;
        font-size: 12px;
    }

    .badge-max {
        background-color: #FF6B35;
        color: white;
        padding: 3px 10px;
        border-radius: 15px;
        font-size: 12px;
    }
</style>

<div class="card">
    <h1>🍵 Панель управления TEA</h1>

    <div class="stats">
        <div class="stat-card">
            <div class="stat-number">@allUsers.Count</div>
            <div>Всего пользователей</div>
        </div>
        <div class="stat-card">
            <div class="stat-number">@vkUsers.Count</div>
            <div>📱 VK</div>
        </div>
        <div class="stat-card">
            <div class="stat-number">@maxUsers.Count</div>
            <div>📲 MAX</div>
        </div>
    </div>

    <!-- Вкладки -->
    <div class="tabs">
        <a href="/?platform=all" class="tab @(platform == "all" ? "tab-active" : "")">🌐 Все</a>
        <a href="/?platform=VK" class="tab @(platform == "VK" ? "tab-active" : "")">📱 VK</a>
        <a href="/?platform=MAX" class="tab @(platform == "MAX" ? "tab-active" : "")">📲 MAX</a>
    </div>
</div>

<div class="card">
    <h2>📋 Список пользователей @(platform == "all" ? "(все)" : platform)</h2>
    @if (displayUsers.Count == 0)
    {
        <p>⚠️ Пользователей пока нет</p>
    }
    else
    {
        <table>
            <thead>
                <tr>
                    <th>ID</th>
                    <th>Платформа</th>
                    <th>Язык</th>
                    <th>Уровень</th>
                    <th>Заявка</th>
                </tr>
            </thead>
            <tbody>
                @foreach (var u in displayUsers)
                {
                    <tr>
                        <td>@u.VkUserId</td>
                        <td>
                            @if (u.Platform == "MAX")
                            {
                                <span class="badge-max">📲 MAX</span>
                            }
                            else
                            {
                                <span class="badge-vk">📱 VK</span>
                            }
                        </td>
                        <td>@u.Language</td>
                        <td>@u.Level</td>
                        <td>@u.Request</td>
                    </tr>
                }
            </tbody>
        </table>
    }
</div>

<div>
    <a href="/Requests?platform=@platform" class="btn">📋 Заявки менеджеру</a>
    <a href="/Broadcast" class="btn">📢 Рассылка</a>
</div>