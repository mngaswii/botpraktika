@page
@using Microsoft.Data.Sqlite
@using System.IO
@{
    // Путь к файлу базы данных
    string dbPath = @"C:\Users\Professionals\Desktop\Практика\bot\botAdmin\teabot.db";

    // СОЗДАЁМ ТАБЛИЦЫ, ЕСЛИ ИХ НЕТ
    using (var connection = new SqliteConnection($"Data Source={dbPath}"))
    {
        connection.Open();

        string createUsers = @"
            CREATE TABLE IF NOT EXISTS Users (
                VkUserId INTEGER PRIMARY KEY,
                Language TEXT,
                Level TEXT,
                RequestText TEXT
            )";
        using (var cmd = new SqliteCommand(createUsers, connection))
            cmd.ExecuteNonQuery();

        string createRequests = @"
            CREATE TABLE IF NOT EXISTS ManagerRequests (
                Id INTEGER PRIMARY KEY AUTOINCREMENT,
                VkUserId INTEGER,
                RequestText TEXT,
                Status TEXT DEFAULT 'new',
                CreatedAt DATETIME DEFAULT CURRENT_TIMESTAMP
            )";
        using (var cmd = new SqliteCommand(createRequests, connection))
            cmd.ExecuteNonQuery();
    }

    var users = new List<dynamic>();

    using (var connection = new SqliteConnection($"Data Source={dbPath}"))
    {
        connection.Open();
        var cmd = new SqliteCommand("SELECT VkUserId, Language, Level, RequestText FROM Users", connection);
        var reader = cmd.ExecuteReader();
        while (reader.Read())
        {
            users.Add(new
            {
                VkUserId = reader.GetInt64(0),
                Language = reader.IsDBNull(1) ? "—" : reader.GetString(1),
                Level = reader.IsDBNull(2) ? "—" : reader.GetString(2),
                Request = reader.IsDBNull(3) ? "—" : reader.GetString(3)
            });
        }
    }
}

<style>
    body {
        background-color: #F2DDCC;
        font-family: 'Segoe UI', sans-serif;
        margin: 0;
        padding: 20px;
    }

    h1 {
        color: #85544D;
    }

    .card {
        background-color: #F1C7A7;
        border-radius: 12px;
        padding: 20px;
        border: 1px solid #B1B6B2;
        margin-bottom: 20px;
    }

    table {
        width: 100%;
        border-collapse: collapse;
        background-color: #F2DDCC;
    }

    th {
        background-color: #B1B6B2;
        color: white;
        padding: 12px;
        text-align: left;
    }

    td {
        padding: 10px;
        border-bottom: 1px solid #B1B6B2;
    }

    .btn {
        background-color: #85544D;
        color: white;
        padding: 10px 20px;
        border: none;
        border-radius: 25px;
        cursor: pointer;
        text-decoration: none;
        display: inline-block;
        margin-right: 10px;
    }

        .btn:hover {
            background-color: #6B3E38;
        }

    .stats {
        display: flex;
        gap: 20px;
        margin-bottom: 20px;
    }

    .stat-card {
        background-color: #F1C7A7;
        padding: 15px 25px;
        border-radius: 12px;
        text-align: center;
        border: 1px solid #B1B6B2;
    }

    .stat-number {
        font-size: 28px;
        font-weight: bold;
        color: #85544D;
    }
</style>

<div class="card">
    <h1>🍵 Панель управления TEA</h1>

    <div class="stats">
        <div class="stat-card">
            <div class="stat-number">@users.Count</div>
            <div>Всего пользователей</div>
        </div>
        <div class="stat-card">
            <div class="stat-number">@users.Count(u => u.Language != "—")</div>
            <div>Выбрали язык</div>
        </div>
        <div class="stat-card">
            <div class="stat-number">@users.Count(u => u.Request != "—")</div>
            <div>Оставили заявку</div>
        </div>
    </div>
</div>

<div class="card">
    <h2>📋 Список пользователей</h2>
    <table>
        <thead>
            <tr><th>VK ID</th><th>Язык</th><th>Уровень</th><th>Заявка</th></tr>
        </thead>
        <tbody>
            @foreach (var u in users)
            {
                <tr>
                    <td>@u.VkUserId</td>
                    <td>@u.Language</td>
                    <td>@u.Level</td>
                    <td>@u.Request</td>
                </tr>
            }
        </tbody>
    </table>
</div>

<div>
    <a href="/Requests" class="btn">📋 Заявки менеджеру</a>
    <a href="/Broadcast" class="btn">📢 Рассылка</a>
</div>