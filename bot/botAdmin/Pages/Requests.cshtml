@page
@using TeaBotSimple
@{
    string platform = Request.Query["platform"].ToString();
    if (string.IsNullOrEmpty(platform)) platform = "all";

    var allRequests = Database.GetRequests();
    var displayRequests = platform == "all" ? allRequests : allRequests.Where(r => r.Platform == platform).ToList();
}

<style>
    body {
        background-color: #F2DDCC;
        font-family: 'Segoe UI', sans-serif;
        padding: 20px;
    }

    h1 {
        color: #85544D;
    }

    .card {
        background-color: #F1C7A7;
        border-radius: 12px;
        padding: 20px;
        border: 1px solid #B1B6B2;
        margin-bottom: 20px;
    }

    table {
        width: 100%;
        border-collapse: collapse;
        background-color: #F2DDCC;
    }

    th {
        background-color: #B1B6B2;
        color: white;
        padding: 12px;
        text-align: left;
    }

    td {
        padding: 10px;
        border-bottom: 1px solid #B1B6B2;
    }

    .status-new {
        color: #85544D;
        font-weight: bold;
    }

    .status-closed {
        color: #B1B6B2;
    }

    .btn {
        background-color: #85544D;
        color: white;
        padding: 8px 16px;
        border: none;
        border-radius: 20px;
        cursor: pointer;
        text-decoration: none;
        display: inline-block;
    }

    .badge-vk {
        background-color: #4A76A8;
        color: white;
        padding: 2px 8px;
        border-radius: 12px;
        font-size: 11px;
    }

    .badge-max {
        background-color: #FF6B35;
        color: white;
        padding: 2px 8px;
        border-radius: 12px;
        font-size: 11px;
    }

    .tabs {
        display: flex;
        gap: 10px;
        margin-bottom: 20px;
        flex-wrap: wrap;
    }

    .tab {
        padding: 8px 20px;
        border-radius: 20px;
        background-color: #F1C7A7;
        color: #85544D;
        text-decoration: none;
        border: 1px solid #B1B6B2;
    }

    .tab-active {
        background-color: #85544D;
        color: white;
    }

    a {
        color: #85544D;
    }
</style>

<div class="card">
    <h1>📋 Заявки менеджеру</h1>

    <div class="tabs">
        <a href="/Requests?platform=all" class="tab @(platform == "all" ? "tab-active" : "")">🌐 Все</a>
        <a href="/Requests?platform=VK" class="tab @(platform == "VK" ? "tab-active" : "")">📱 VK</a>
        <a href="/Requests?platform=MAX" class="tab @(platform == "MAX" ? "tab-active" : "")">📲 MAX</a>
    </div>

    @if (displayRequests.Count == 0)
    {
        <p>✨ Заявок пока нет</p>
    }
    else
    {
        <table>
            <thead>
                <tr>
                    <th>ID</th>
                    <th>Платформа</th>
                    <th>VK ID</th>
                    <th>Текст</th>
                    <th>Статус</th>
                    <th>Дата</th>
                </tr>
            </thead>
            <tbody>
                @foreach (var r in displayRequests)
                {
                    <tr>
                        <td>@r.Id</td>
                        <td>
                            @if (r.Platform == "MAX")
                            {
                                <span class="badge-max">📲 MAX</span>
                            }
                            else
                            {
                                <span class="badge-vk">📱 VK</span>
                            }
                        </td>
                        <td>@r.VkUserId</td>
                        <td>@r.RequestText</td>
                        <td class="status-@r.Status">@(r.Status == "new" ? "🆕 Новая" : "✅ Закрыта")</td>
                        <td>@r.CreatedAt.ToString("dd.MM.yyyy HH:mm")</td>
                    </tr>
                }
            </tbody>
        </table>
    }
</div>

<div>
    <a href="/?platform=@platform">← Назад к пользователям</a>
</div>